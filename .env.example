# Copy this file to .env and fill in your values

# Required: OpenAI API key (for GPT-4o image matching and descriptions)
OPENAI_API_KEY=sk-...

# Required: Gmail credentials for sending OTP emails
# Use a Gmail account with App Password (not your main password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Optional: Session secret (change this to something random)
SESSION_SECRET=campusfind-secret-change-me

# Port (Render sets this automatically)
PORT=3000
